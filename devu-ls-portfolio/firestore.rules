rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: contacts
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - email: string (required, valid email format)
    //   - message: string (required, 1-5000 chars)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "lsdevu3@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidContact(data) {
      return data.name is string && data.name.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.message is string && data.message.size() > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /contacts/{contactId} {
      // Anyone can submit a contact form
      allow create: if isValidContact(request.resource.data);
      
      // Only admins can read or manage contact submissions
      allow read, update, delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
